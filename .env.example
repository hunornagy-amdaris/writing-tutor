# OpenRouter (essay analysis — OpenAI-compatible API)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Writing Tutor
# OPENROUTER_SITE_URL=https://your-deployment.vercel.app

# HuggingFace Inference API (free tier) — used for real RoBERTa fill-mask
# phraseology checking on FacebookAI/roberta-base.
HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_FILL_MASK_URL=https://router.huggingface.co/hf-inference/models/FacebookAI/roberta-base
# Paid HF Inference Endpoint serving KevSun/Engessay_grading_ML — once set, the
# five KevSun-mapped PTE criteria come from the real model instead of the LLM.
# Leave blank to fall back to LLM-emulated scoring.
# HUGGINGFACE_KEVSUN_ENDPOINT_URL=https://<your-endpoint>.endpoints.huggingface.cloud

# ElevenLabs Conversational AI (voice tutor) — public agents, no API key needed client-side
# Per-sentence Review tutor (step 3) — see ELEVENLABS_AGENT_PROMPT.md
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_...
# Brainstorm tutor (step 1) — separate agent, see BRAINSTORM_AGENT_PROMPT.md
NEXT_PUBLIC_ELEVENLABS_BRAINSTORM_AGENT_ID=
